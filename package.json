{
  "name": "ping-chat",
  "version": "0.2.10",
  "description": "Ping Chat desktop workspace",
  "private": true,
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "pnpm build && electron-builder",
    "test": "vitest run"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-tooltip": "^1.2.9",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "2.1.9"
  },
  "build": {
    "appId": "com.ping.chat",
    "productName": "Ping Chat",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "sipingme",
      "repo": "ping-chat",
      "releaseType": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Network"
    }
  }
}
